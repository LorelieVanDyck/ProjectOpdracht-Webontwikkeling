<%- include("partials/header") %>

<h1>Streetfoods</h1>

<!-- Bericht: Geen gevonden resultaten -->
<% if (noResults) { %>

    <p>Geen streetfoods gevonden met zoekopdracht: "<%= search %>"</p>

<% } %>


<!-- Tabel met zoekresultaten -->
<% if (streetfoods.length === 0) { %>

    <p>Geen resultaten gevonden</p>

<% } else { %>

<table>

    <thead>
        <tr>

            <!-- IMAGE -->
            <th>Afbeelding</th>

            <!-- NAME SORT -->
            <th>
                <a href="/streetfoods?search_bar=<%= search %>&sortField=name&sortDirection=<%= sortField === 'name' && sortDirection === 'asc' ? 'desc' : 'asc' %>">
                    Naam
                    <% if (sortField === "name") { %>
                        <%= sortDirection === "asc" ? "▲" : "▼" %>
                    <% } %>
                </a>
            </th>

            <!-- DESCRIPTION -->
            <th>Beschrijving</th>

            <!-- CATEGORY SORT -->
            <th>
                <a href="/streetfoods?search_bar=<%= search %>&sortField=category&sortDirection=<%= sortField === 'category' && sortDirection === 'asc' ? 'desc' : 'asc' %>">
                    Categorie
                    <% if (sortField === "category") { %>
                        <%= sortDirection === "asc" ? "▲" : "▼" %>
                    <% } %>
                </a>
            </th>

            <!-- PRICE SORT -->
            <th>
                <a href="/streetfoods?search_bar=<%= search %>&sortField=priceTier&sortDirection=<%= sortField === 'priceTier' && sortDirection === 'asc' ? 'desc' : 'asc' %>">
                    Prijs
                    <% if (sortField === "priceTier") { %>
                        <%= sortDirection === "asc" ? "▲" : "▼" %>
                    <% } %>
                </a>
            </th>

            <!-- SPICE SORT -->
            <th>
                <a href="/streetfoods?search_bar=<%= search %>&sortField=spiceLevel&sortDirection=<%= sortField === 'spiceLevel' && sortDirection === 'asc' ? 'desc' : 'asc' %>">
                    Spice Level
                    <% if (sortField === "spiceLevel") { %>
                        <%= sortDirection === "asc" ? "▲" : "▼" %>
                    <% } %>
                </a>
            </th>

            <!-- POPULARITY -->
            <th>Populariteit</th>

        </tr>
    </thead>

    <tbody>

        <% for (let food of streetfoods) { %>

        <tr class="clickable-row"
            onclick="window.location='/streetfoods/<%= food.id %>'">

            <td>
                <img src="<%= food.imageUrl %>" alt="<%= food.name %>" width="100px">
            </td>

            <td><%= food.name %></td>
            <td><%= food.description %></td>
            <td><%= food.category %></td>
            <td><%= food.priceTier %></td>

            <td>
                <%= food.spiceLevel > 0 ? "🌶️".repeat(food.spiceLevel) : "-" %>
            </td>

            <td>
                <%= food.isPopular ? "🔥 Popular" : "-" %>
            </td>

        </tr>

        <% } %>

    </tbody>

</table>

<% } %>

<%- include("partials/footer") %>