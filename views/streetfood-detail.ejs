<%- include("partials/header") %>

<h1><%= streetfood.name %></h1>

<!-- STREETFOOD INFO -->
<article class="detail-card">
    <img src="<%= streetfood.imageUrl %>" alt="<%= streetfood.name %>">
    <div class="detail-info">
        <h2>Beschrijving</h2>
        <p><%= streetfood.description %></p>

        <h2>Details</h2>
        <p><strong>Categorie:</strong> <%= streetfood.category %></p>
        <p><strong>Prijs:</strong> <%= streetfood.priceTier %> of €€€</p>
        <p>
            <strong>Spice Level:</strong>
            <%= streetfood.spiceLevel > 0 ? "🌶️".repeat(streetfood.spiceLevel) : "🫑" %>
        </p>
        <p>
            <strong>Populariteit:</strong>
            <%= streetfood.isPopular ? "🔥 Favoriet" : "Normaal" %>
        </p>
        <p>
            <strong>First Served:</strong>
            <%= new Date(streetfood.firstServedDate).toLocaleDateString("nl-Be") %>
        </p>
        <p>
            <strong>Tags:</strong>
            <%= streetfood.tags.join(", ") %>
        </p>
    </div>
</article>


<!-- VENDOR INFO -->
<h2>Wie is de vendor?</h2>

<article class="sub-card clickable-row" onclick="window.location='/vendors/<%= streetfood.vendor.id %>'">
    <img src="<%= streetfood.vendor.standImageUrl %>" alt="<%= streetfood.vendor.name %>">
    <div class="sub-card-info">
        <h3><%= streetfood.vendor.name %></h3>
        <p><strong>Locatie:</strong> <%= streetfood.vendor.city %>, <%= streetfood.vendor.country %></p>
        <p><strong>Sinds:</strong> <%= streetfood.vendor.sinceYear %></p>
        <p><strong>Specialiteit:</strong> <%= streetfood.vendor.specialty %></p>
        <p><strong>Gemiddelde prijs:</strong> € <%= streetfood.vendor.averagePriceEur?.toFixed(2).replace(".", ",") %></p>
        <p><strong>Status:</strong> <%= streetfood.vendor.isOpenNow ? "🟢 Open" : "🔴 Gesloten" %></p>
    </div>
</article>


<!-- ANDERE STREETFOODS VAN DEZELFDE VENDOR -->
<h2>Andere streetfoods van dezelfde vendor</h2>

<% if (sameVendorFoods.length === 0) { %>
    <p>Geen andere streetfoods gevonden.</p>
<% } else { %>
    <div class="sub-cards-grid">
    <% for (let food of sameVendorFoods) { %>
        <article class="sub-card clickable-row" onclick="window.location='/streetfoods/<%= food.id %>'">
            <img src="<%= food.imageUrl %>" alt="<%= food.name %>">
            <div class="sub-card-info">
                <h3><%= food.name %></h3>
                <p><strong>Categorie:</strong> <%= food.category %></p>
                <p><strong>Prijs:</strong> <%= food.priceTier %> of €€€<p>
                <p>
                    <strong>Spice Level:</strong>
                    <%= streetfood.spiceLevel > 0 ? "🌶️".repeat(streetfood.spiceLevel) : "🫑" %>
                </p>
                <p>
                    <strong>Populariteit:</strong>
                    <%= streetfood.isPopular ? "🔥 Favoriet" : "Normaal" %>
                </p>
            </div>
        </article>
    <% } %>
    </div>
<% } %>

<%- include("partials/footer") %>