<aside class="sidebar">

    <h2 class="logo">
        <span class="logo-icon">🍜</span>
        <span class="logo-text">UrbanTaste</span>
    </h2>

    <% if (showSearch) { %>
        <h3>Search</h3>

        <form method="GET" action="<%= searchAction %>">
            <input type="text" name="search_bar" placeholder="<%= searchPlaceholder || 'Zoek...' %>" value="<%= search || '' %>">
            <button type="submit">Zoek</button>
        </form>
    <% } %>

    <h3>Navigation</h3>

    <nav>
        <a href="/">Home</a>
        <a href="/streetfoods">Streetfoods</a>
        <a href="/vendors">Vendors</a>
    </nav>

</aside>