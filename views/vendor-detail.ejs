<%- include("partials/header") %>

<h1><%= vendor.name %></h1>

<!-- VENDOR INFO: afbeelding links, details rechts -->
<article class="detail-card">
    <img src="<%= vendor.standImageUrl %>" alt="<%= vendor.name %>">

    <div class="detail-info">
        <h2>Locatie</h2>
        <p><%= vendor.city %>, <%= vendor.country %></p>

        <h2>Details</h2>
        <p><strong>Sinds:</strong> <%= vendor.sinceYear %></p>
        <p><strong>Specialiteit:</strong> <%= vendor.specialty %></p>
        <p><strong>Gemiddelde prijs:</strong> € <%= vendor.averagePriceEur?.toFixed(2).replace(".", ",") %></p>
        <p><strong>Status:</strong> <%= vendor.isOpenNow ? "🟢 Open" : "🔴 Gesloten" %></p>
    </div>
</article>


<!-- STREETFOODS VAN DEZE VENDOR -->
<h2>Streetfoods van deze vendor</h2>

<% if (vendorFoods.length === 0) { %>
    <p>Geen streetfoods gevonden.</p>
<% } else { %>
    <div class="sub-cards-grid">
    <% for (let food of vendorFoods) { %>
        <article class="sub-card clickable-row" onclick="window.location='/streetfoods/<%= food.id %>'">
            <img src="<%= food.imageUrl %>" alt="<%= food.name %>">
            <div class="sub-card-info">
                <h3><%= food.name %></h3>
                <p><strong>Categorie:</strong> <%= food.category %></p>
                <p><strong>Prijs:</strong> <%= food.priceTier %> of €€€ </p>
                <p><strong>Spice Level:</strong> <%= "🌶️".repeat(food.spiceLevel) %></p>
                <p><strong>Populariteit:</strong> <%= food.isPopular ? "🔥 Favoriet" : "Normaal" %></p>
            </div>
        </article>
    <% } %>
    </div>
<% } %>

<%- include("partials/footer") %>